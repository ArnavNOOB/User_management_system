<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - User Management System</title>
  <!-- Bootstrap 5 CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Custom Beige Style -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Navigation Bar -->
  <nav class="navbar navbar-expand-lg navbar-beige shadow-sm">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center" href="/">
        <!-- Small Key/Shield logo -->
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#8c7853" class="bi bi-shield-fill-check me-2" viewBox="0 0 16 16">
          <path fill-rule="evenodd" d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.777 11.777 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7.159 7.159 0 0 0 1.048-.625 11.775 11.775 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.54 1.54 0 0 0-1.044-1.263 62.467 62.467 0 0 0-2.887-.87C9.843.266 8.69 0 8 0zm2.146 5.146a.5.5 0 0 1 .708.708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 7.793l2.646-2.647z"/>
        </svg>
        <span>User Directory Portal</span>
      </a>
      <div class="d-flex align-items-center">
        <span class="me-3 d-none d-sm-inline-block text-secondary">
          Logged in as: <strong><%= user.name %></strong> (<%= user.role.toUpperCase() %>)
        </span>
        <img src="<%= user.profilePicture %>" alt="Avatar" class="profile-pic-sm me-3">
        <a href="/auth/logout" class="btn btn-outline-danger btn-sm">Log Out</a>
      </div>
    </div>
  </nav>

  <!-- Main Container -->
  <div class="container py-5">
    
    <!-- Alerts -->
    <% if (errorMsg) { %>
      <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <%= errorMsg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <% if (successMsg) { %>
      <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <%= successMsg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <!-- ROLE-BASED CONDITIONAL VIEWS -->
    <% if (user.role === 'admin') { %>
      
      <!-- ========================================================================= -->
      <!-- ADMIN VIEW: DASHBOARD AND USERS MANAGEMENT -->
      <!-- ========================================================================= -->
      <div class="row mb-4 align-items-center">
        <div class="col-md-8">
          <h2 class="text-dark font-weight-bold mb-1">Administrative Control Panel</h2>
          <p class="text-secondary">Manage and modify system user accounts from a central interface.</p>
        </div>
        <div class="col-md-4 text-md-end">
          <span class="badge bg-secondary p-2 font-weight-bold">🔒 LOCKED FOR REGULAR USERS</span>
        </div>
      </div>

      <!-- Dashboard Statistics Row -->
      <div class="row mb-5">
        <div class="col-md-4">
          <div class="card p-3 border-0 bg-white shadow-sm">
            <h6 class="text-uppercase text-secondary font-weight-bold text-sm mb-2">Total Directory Users</h6>
            <div class="d-flex align-items-center">
              <h2 class="text-dark font-weight-bold mb-0"><%= users.length %></h2>
              <span class="badge bg-success-subtle text-success ms-3 px-2 py-1 font-weight-bold">Active</span>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-3 border-0 bg-white shadow-sm">
            <h6 class="text-uppercase text-secondary font-weight-bold text-sm mb-2">System Admin</h6>
            <h6 class="text-dark font-weight-bold mb-0">admin@gmail.com</h6>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card p-3 border-0 bg-white shadow-sm">
            <h6 class="text-uppercase text-secondary font-weight-bold text-sm mb-2">Primary Storage</h6>
            <h6 class="text-dark font-weight-bold mb-0">Local File Storage</h6>
          </div>
        </div>
      </div>

      <!-- Users List Card -->
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
          <h5 class="card-title text-dark font-weight-bold mb-0">User Directory</h5>
        </div>
        
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-beige table-striped table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th class="ps-4">Avatar</th>
                  <th>Full Name</th>
                  <th>Email Address</th>
                  <th>Contact Number</th>
                  <th>Registered At</th>
                  <th class="text-end pe-4">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (users.length === 0) { %>
                  <tr>
                    <td colspan="6" class="text-center py-5 text-secondary">
                      No registered users in the database directory.
                    </td>
                  </tr>
                <% } else { %>
                  <% users.forEach(function(u) { %>
                    <tr>
                      <td class="ps-4">
                        <img src="<%= u.profilePicture %>" alt="<%= u.name %>" class="profile-pic-sm">
                      </td>
                      <td class="font-weight-bold text-dark"><%= u.name %></td>
                      <td><%= u.email %></td>
                      <td><%= u.contact %></td>
                      <td><%= new Date(u.createdAt).toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                      <td class="text-end pe-4">
                        <!-- Edit Button (Triggers Modal) -->
                        <button type="button" class="btn btn-outline-beige btn-sm me-2" data-bs-toggle="modal" data-bs-target="#editModal-<%= u._id %>">
                          Edit
                        </button>
                        <!-- Delete Button (POST Form for confirmation) -->
                        <form action="/admin/delete/<%= u._id %>" method="POST" class="d-inline" onsubmit="return confirm('Are you absolutely sure you want to permanently delete the user account for \'<%= u.name %>\'? This action cannot be undone.');">
                          <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                        </form>
                      </td>
                    </tr>

                    <!-- EDIT USER MODAL -->
                    <div class="modal fade" id="editModal-<%= u._id %>" tabindex="-1" aria-labelledby="editModalLabel-<%= u._id %>" aria-hidden="true">
                      <div class="modal-dialog">
                        <div class="modal-content">
                          <div class="modal-header">
                            <h5 class="modal-title text-dark font-weight-bold" id="editModalLabel-<%= u._id %>">Edit User Account</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                          </div>
                          <form action="/admin/update" method="POST">
                            <input type="hidden" name="userId" value="<%= u._id %>">
                            <div class="modal-body text-start">
                              
                              <div class="mb-3">
                                <label for="editName-<%= u._id %>" class="form-label">Full Name</label>
                                <input type="text" class="form-control" id="editName-<%= u._id %>" name="name" value="<%= u.name %>" required>
                              </div>

                              <div class="mb-3">
                                <label for="editEmail-<%= u._id %>" class="form-label">Email Address</label>
                                <input type="email" class="form-control" id="editEmail-<%= u._id %>" name="email" value="<%= u.email %>" required>
                              </div>

                              <div class="mb-3">
                                <label for="editContact-<%= u._id %>" class="form-label">Contact Number</label>
                                <input type="tel" class="form-control" id="editContact-<%= u._id %>" name="contact" value="<%= u.contact %>" required>
                              </div>

                            </div>
                            <div class="modal-footer bg-light">
                              <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                              <button type="submit" class="btn btn-beige btn-sm">Save Changes</button>
                            </div>
                          </form>
                        </div>
                      </div>
                    </div>
                  <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    <% } else { %>
      
      <!-- ========================================================================= -->
      <!-- USER VIEW: INDIVIDUAL ACCOUNT CARD -->
      <!-- ========================================================================= -->
      <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
          
          <div class="text-center mb-4">
            <h2 class="text-dark font-weight-bold">Your Account Profile</h2>
            <p class="text-secondary text-sm">Welcome back to your dashboard portal</p>
          </div>

          <div class="card p-4 text-center border-0 shadow-sm">
            
            <div class="mb-4">
              <div class="profile-pic-container">
                <img src="<%= user.profilePicture %>" alt="<%= user.name %>">
              </div>
            </div>

            <h3 class="text-dark font-weight-bold mb-1"><%= user.name %></h3>
            <span class="badge bg-secondary-subtle text-secondary px-3 py-1 font-weight-bold mb-4">ROLE: <%= user.role.toUpperCase() %></span>
            
            <hr class="my-4">

            <div class="text-start">
              <div class="mb-3">
                <small class="text-secondary text-uppercase font-weight-bold text-xs d-block">Registered Email</small>
                <span class="text-dark font-weight-bold"><%= user.email %></span>
              </div>

              <div class="mb-3">
                <small class="text-secondary text-uppercase font-weight-bold text-xs d-block">Contact Number</small>
                <span class="text-dark font-weight-bold"><%= user.contact %></span>
              </div>
            </div>

            <!-- Informational Banner about Access Level -->
            <div class="mt-4 p-3 bg-light border rounded text-start">
              <div class="d-flex align-items-start">
                <div class="me-2 text-warning">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-lock-fill" viewBox="0 0 16 16">
                    <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                  </svg>
                </div>
                <div>
                  <small class="font-weight-bold d-block text-dark">Directory Dashboard Locked</small>
                  <small class="text-muted text-xs">The administrative dashboard directory containing details of other users is exclusively locked and visible to the admin account (<strong class="text-dark">admin@gmail.com</strong>) only.</small>
                </div>
              </div>
            </div>

          </div>

        </div>
      </div>

    <% } %>

  </div>

  <!-- Bootstrap Bundle with Popper JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
