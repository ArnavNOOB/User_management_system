<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <!-- Bootstrap 5 CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Custom Beige Style -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container py-5 mt-5">
    <div class="row justify-content-center">
      <div class="col-md-7 text-center">
        <div class="card p-5 border-danger">
          <div class="card-body">
            <div class="mb-4">
              <!-- Locked padlock icon -->
              <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="#dc3545" class="bi bi-shield-lock-fill" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M8 0c-.69 0-1.843.265-2.928.56-1.11.3-2.229.655-2.887.87a1.54 1.54 0 0 0-1.044 1.262c-.596 4.477.787 7.795 2.465 9.99a11.777 11.777 0 0 0 2.517 2.453c.386.273.744.482 1.048.625.28.132.581.24.829.24s.548-.108.829-.24a7.159 7.159 0 0 0 1.048-.625 11.775 11.775 0 0 0 2.517-2.453c1.678-2.195 3.061-5.513 2.465-9.99a1.54 1.54 0 0 0-1.044-1.263 62.467 62.467 0 0 0-2.887-.87C9.843.266 8.69 0 8 0zm0 5a1.5 1.5 0 0 1 .5 2.915V9a1.5 1.5 0 0 1-3 0V7.915A1.5 1.5 0 0 1 8 5z"/>
              </svg>
            </div>
            <h1 class="display-3 text-danger font-weight-bold"><%= errorCode %></h1>
            <h3 class="mb-4 text-dark font-weight-bold"><%= title %></h3>
            <p class="lead mb-4 text-secondary"><%= errorMessage %></p>
            <hr class="my-4">
            <a href="/" class="btn btn-beige px-4">Back to Homepage</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
