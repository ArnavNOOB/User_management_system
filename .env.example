# Server Settings
PORT=3000
SESSION_SECRET=your_super_secret_session_key

# MongoDB Atlas Connection URI
# Replace with your actual MongoDB Atlas cluster connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/user_management?retryWrites=true&w=majority

# Seed Admin User Configuration
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=System Admin
ADMIN_CONTACT=9999999999

# Cloudinary Cloud Storage Configuration (Optional)
# If left blank, the system automatically uses local file storage inside 'public/uploads/profilepictures'
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
